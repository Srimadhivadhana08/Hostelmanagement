# ============================================================
# 🚀 HOSTEL HUB — Deployment Guide for Railway
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to Git.

# ------------------------------------------------------------
# 🗄️ Database (MongoDB Atlas)
# ------------------------------------------------------------
# Paste your full MongoDB connection string here.
# Get it from: MongoDB Atlas > Your Cluster > Connect > Drivers > Node.js
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/hostel-management?retryWrites=true&w=majority"

# ------------------------------------------------------------
# 🔐 NextAuth.js (Authentication)
# ------------------------------------------------------------
# 1. Change NEXTAUTH_URL to your Railway deployment URL
#    after you deploy (Step 14 in the deployment guide).
# 2. NEXTAUTH_SECRET: This is your app's password.
#    Use the one below or generate a new one with:
#    node -e "require('crypto').randomBytes(32).toString('base64')|%{$_}"

NEXTAUTH_URL="https://YOUR-APP-NAME.up.railway.app"
NEXTAUTH_SECRET="v0+owe8QFLNLkQmF75u3OrkZSLCwuIq138RLrVvqwao="

# ------------------------------------------------------------
# 📁 File Uploads (Optional — only for avatar uploads)
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
