generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== USER MODEL ====================
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  password      String
  name          String
  role          Role      @default(STUDENT)
  department    String?
  year          Int?
  phone         String?
  address       String?
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  room          Room?     @relation(fields: [roomId], references: [id])
  roomId        String?   @db.ObjectId
  
  bookings      Booking[]
  complaints    Complaint[]
  attendance    Attendance[]
  fees          Fee[]
  outpasses     Outpass[]
  messAttendances MessAttendance[]

  @@index([role])
  @@index([department])
  @@index([roomId])
  @@map("users")
}

enum Role {
  ADMIN
  WARDEN
  STUDENT
}

// ==================== ROOM MODEL ====================
model Room {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  roomNumber    String    @unique
  type          RoomType  @default(SINGLE)
  capacity      Int       @default(2)
  occupied      Int       @default(0)
  price         Float
  status        RoomStatus @default(AVAILABLE)
  amenities     String[]
  floor         String?
  block         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  occupancyRate Float    @default(0) // (occupied/capacity)*100
  
  // Relations
  students      User[]
  bookings      Booking[]

  @@index([status])
  @@index([block, floor])
  @@map("rooms")
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

// ==================== BOOKING MODEL ====================
model Booking {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  roomId        String    @db.ObjectId
  checkIn       DateTime
  checkOut      DateTime?
  status        BookingStatus @default(PENDING)
  totalAmount   Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id])
  room          Room      @relation(fields: [roomId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// ==================== OUTPASS MODEL ====================
model Outpass {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  reason        String
  destination   String
  fromDate      DateTime
  toDate        DateTime
  status        OutpassStatus @default(PENDING)
  
  // HOD Approval
  hodApprovedBy String?   @db.ObjectId
  hodApprovedAt DateTime?
  hodRemarks    String?
  
  // Warden Approval
  approvedBy    String?   @db.ObjectId
  approvedAt    DateTime?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("outpasses")
}

enum OutpassStatus {
  PENDING
  PENDING_WARDEN
  APPROVED
  REJECTED
  EXPIRED
}

// ==================== COMPLAINT MODEL ====================
model Complaint {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  title         String
  description   String
  category      ComplaintCategory
  status        ComplaintStatus @default(OPEN)
  priority      Priority  @default(MEDIUM)
  assignedTo    String?   @db.ObjectId
  resolvedAt    DateTime?
  resolution    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("complaints")
}

enum ComplaintCategory {
  ELECTRICAL
  PLUMBING
  FURNITURE
  CLEANING
  SECURITY
  NOISE
  FOOD
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==================== ATTENDANCE MODEL ====================
model Attendance {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  date          DateTime
  status        AttendanceStatus
  checkInTime   DateTime?
  checkOutTime  DateTime?
  markedBy      String?   @db.ObjectId
  notes         String?
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HOLIDAY
}

// ==================== FEE MODEL ====================
model Fee {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  month         String    // "January", "February", etc.
  year          Int
  roomRent      Float
  messCharges   Float
  otherCharges  Float     @default(0)
  totalAmount   Float
  paid          Float     @default(0)
  due           Float
  status        FeeStatus @default(PENDING)
  paidAt        DateTime?
  transactionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("fees")
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

// ==================== MESS MODEL ====================
model Mess {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime
  breakfast     String
  lunch         String
  dinner        String
  special       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  attendances   MessAttendance[]

  @@unique([date])
  @@map("mess")
}

model MessAttendance {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  messId        String    @db.ObjectId
  breakfast     Boolean   @default(false)
  lunch         Boolean   @default(false)
  dinner        Boolean   @default(false)
  date          DateTime
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id])
  mess          Mess      @relation(fields: [messId], references: [id])

  @@unique([userId, date])
  @@map("mess_attendance")
}

// ==================== NOTICE MODEL ====================
model Notice {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  content       String
  category      NoticeCategory @default(GENERAL)
  priority      Priority  @default(MEDIUM)
  postedBy      String    @db.ObjectId
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("notices")
}

enum NoticeCategory {
  GENERAL
  URGENT
  EVENT
  MAINTENANCE
  MESS
  FEE
}